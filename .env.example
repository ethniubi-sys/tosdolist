# ============ 服务端 API（vercel dev / Vercel 部署）============
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_key
GEMINI_API_KEY=your_gemini_key
DOUBAO_API_KEY=your_doubao_key
DOUBAO_MODEL=doubao-seed-1-8-251228

# ============ npm run dev 直连 LLM（可选）============
# 复制到 .env.development.local，仅开发时使用，不会打进生产包
# VITE_DEEPSEEK_API_KEY=your_deepseek_key
# VITE_GEMINI_API_KEY=your_gemini_key
# VITE_DOUBAO_API_KEY=your_doubao_key
# VITE_DOUBAO_MODEL=doubao-seed-1-8-251228
# VITE_LLM_PROVIDER=deepseek

# ============ 其他 ============
# BASE_PATH=/ (Vercel 根路径) 或 /tosdolist/ (GitHub Pages)
