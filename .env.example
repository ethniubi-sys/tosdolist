# ============ Local Development ============
# For local dev with LLM: use `vercel dev` (see README)
# API keys below are only used by api/llm.ts (server-side)

LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_key
GEMINI_API_KEY=your_gemini_key

# Base path for build (optional)
# Use BASE_PATH=/ for Vercel root; /tosdolist/ for GitHub Pages
# BASE_PATH=/
